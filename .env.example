# ── Signal Sources ──────────────────────────────────────────────────────
SIGNAL_SERVER_URL=https://api.thecharon.xyz/api
SIGNAL_SERVER_KEY=your_signal_server_key_here
SIGNAL_POLL_MS=30000

# ── Execution ──────────────────────────────────────────────────────────
TRADING_MODE=dry_run              # dry_run | confirm | live
SOLANA_PRIVATE_KEY=               # Base58-encoded Solana keypair
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
JUPITER_API_KEY=                  # Optional: Jupiter API key
JUPITER_BASE_URL=https://ultra-api.jup.ag
LIVE_MIN_SOL_RESERVE=0.02
DEFAULT_BUY_SOL=0.1
SLIPPAGE_BPS=500

# ── LLM ────────────────────────────────────────────────────────────────
ENABLE_LLM=true
LLM_BASE_URL=https://api.minimax.io/v1
LLM_API_KEY=                      # Optional: LLM API key
LLM_MODEL=MiniMax-M2.7
LLM_CANDIDATE_PICK_COUNT=10
LLM_TIMEOUT_SECS=30

# ── Telegram ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Database ───────────────────────────────────────────────────────────
DATABASE_PATH=charon.db

# ── Position Management ───────────────────────────────────────────────
POSITION_MONITOR_MS=10000
DEFAULT_TP_PERCENT=100.0
DEFAULT_SL_PERCENT=30.0
TRAILING_STOP_PERCENT=             # Optional: e.g. 15
TRAILING_STOP_ACTIVATED_AT_PERCENT= # Optional: e.g. 50

# ── Rate Limits ────────────────────────────────────────────────────────
GMGN_RATE_LIMIT_PER_SEC=2
JUPITER_RATE_LIMIT_PER_SEC=5

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=info
